<ui:FluentWindow x:Class="UZIS_Monitor.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:UZIS_Monitor"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:system="clr-namespace:System;assembly=System.Runtime"
                 xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
                 xmlns:converters="clr-namespace:UZIS_Monitor.Converters"
                 mc:Ignorable="d"
                 Title="UZIS Monitor" Height="480" Width="640"
                 DataContext="{Binding Source={x:Static local:App.MainVM}}"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <Window.Resources>
        <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>

        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" 
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="IconButtonTransparentStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="7,5,6,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="RootElement"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                <Setter TargetName="RootElement" Property="Background" Value="Transparent"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                <Setter TargetName="RootElement" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootElement" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                                <Setter TargetName="RootElement" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="RootElement" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid IsHitTestVisible="{c:Binding !IsBusy}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Background="Transparent">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                    <ui:Button Command="{Binding OpenFileCommand}"
                               Content="{ui:SymbolIcon FolderOpen24}"
                               Style="{StaticResource IconButtonTransparentStyle}"/>
                    <ui:Button Command="{Binding SaveFileCommand}"
                               Content="{ui:SymbolIcon Save24}"
                               Style="{StaticResource IconButtonTransparentStyle}"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <TextBlock Grid.Row="0"
                   Text="UZIS MONITOR"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.8"
                   FontSize="16"
                   FontWeight="SemiBold"
                   FontFamily="Bahnschrift"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   IsHitTestVisible="False">
            <TextBlock.LayoutTransform>
                <ScaleTransform ScaleX="1.1" />
                <!-- Легкая растяжка по горизонтали для солидности -->
            </TextBlock.LayoutTransform>
        </TextBlock>
        <TextBlock Grid.Row="0"
                   Text="{Binding FileName}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Opacity="0.8"
                   FontSize="10"
                   FontWeight="Regular"
                   Foreground="{DynamicResource TextFillColorDisabledBrush}"
                   IsHitTestVisible="False">
            <TextBlock.LayoutTransform>
                <ScaleTransform ScaleX="0.9" />
                <!-- Легкая растяжка по горизонтали для солидности -->
            </TextBlock.LayoutTransform>
        </TextBlock>
        <!-- IsHitTestVisible="False" позволяет кликать/перетаскивать окно сквозь текст -->
        <Grid Grid.Row="1" IsEnabled="{Binding IsConnected}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <ui:Button Opacity="0.8" FontWeight="Bold" Command="{Binding ToggleRecordingCommand}" Width="100">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Appearance" Value="Success" />
                            <Setter Property="Content" Value="START" />
                            <Setter Property="Icon" Value="{ui:SymbolIcon Play28}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecordingState}" Value="Waiting">
                                    <Setter Property="Appearance" Value="Danger" />
                                    <Setter Property="Content" Value="STOP" />
                                    <Setter Property="Icon" Value="{ui:SymbolIcon Stop24}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RecordingState}" Value="Recording">
                                    <Setter Property="Appearance" Value="Danger" />
                                    <Setter Property="Content" Value="STOP" />
                                    <Setter Property="Icon" Value="{ui:SymbolIcon Stop24}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <Label HorizontalAlignment="Left" FontFamily="Consolas" Foreground="#40D672" VerticalContentAlignment="Center" Margin="20,0,0,0">
                    <Label.Style>
                        <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
                            <Setter Property="Visibility" Value="Hidden" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecordingState}" Value="Waiting">
                                    <Setter Property="Content" Value="wait..." />
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RecordingState}" Value="Recording">
                                    <Setter Property="Content" Value="{Binding RecordTime}" />
                                    <Setter Property="ContentStringFormat" Value="mm\:ss" />
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                <Grid Width="300" VerticalAlignment="Center">
                    <!-- Используем стандартный ProgressBar, WPF-UI сам его стилизует -->
                    <ProgressBar Value="{Binding CurrentAcc}" Maximum="700">
                        <!--<ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Style.Triggers>
                                    --><!-- Наблюдаем за изменением значения --><!--
                                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation 
                                                    Storyboard.TargetProperty="Value"
                                                    Duration="0:0:0.01">
                                                    --><!--<DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>--><!--
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>-->
                        <ProgressBar.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ResetReakAccCommand}" />
                        </ProgressBar.InputBindings>
                    </ProgressBar>
                    <!-- Сетка для позиционирования метки пика -->
                    <Grid Visibility="{c:Binding 'PeakAcc > 0'}">
                        <Grid.ColumnDefinitions>
                            <!-- Допустим, пик на 80%. В реальности тут будет Binding -->
                            <ColumnDefinition Width="{Binding PeakAcc, Converter={converters:DoubleToGridLengthConverter}}"/>
                            <ColumnDefinition Width="{Binding PeakAcc, Converter={converters:DoubleToGridLengthConverter}, ConverterParameter=700}"/>
                        </Grid.ColumnDefinitions>
                        <!-- Маркер пика (тонкая вертикальная линия) -->
                        <Border Grid.Column="0" 
                                HorizontalAlignment="Right"
                                Width="4" 
                                Height="12"
                                CornerRadius="2"
                                Background="Red"
                                Margin="0,0,-2,0"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ResetReakAccCommand}" />
                            </Border.InputBindings>
                        </Border>
                    </Grid>
                </Grid>

                <Label Margin="10,5,10,0" Opacity="{c:Binding 'OffCount > 0 ? 1 : 0.25'}" FontSize="16" VerticalContentAlignment="Center" FontFamily="Consolas" Cursor="Hand" VerticalAlignment="Center">
                    <Label.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ResetOffCountCommand}" />
                    </Label.InputBindings>
                    <Label.Content>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Pulse24" Foreground="Orange" Margin="0,0,2,0" VerticalAlignment="Center"></ui:SymbolIcon>
                            <TextBlock Text="{Binding OffCount}" Foreground="Orange" VerticalAlignment="Center" FontWeight="Bold"></TextBlock>
                        </StackPanel>
                    </Label.Content>
                </Label>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20, 0">
                <ui:Button Command="{Binding ClearDataCommand}"
                           Content="{ui:SymbolIcon Delete24}"
                           Style="{StaticResource IconButtonTransparentStyle}"/>
            </StackPanel>
        </Grid>
        <!--<StatusBar Grid.Row="3" Padding="12, 4">
            <Label Content="{Binding StatusMessage}" VerticalContentAlignment="Center"></Label>
            <Separator></Separator>
            <StatusBarItem HorizontalAlignment="Right">
                <Label Content="{Binding SmoothVoltage}" VerticalContentAlignment="Center"></Label>
            </StatusBarItem>
        </StatusBar>-->
        <Border Grid.Row="3"
                Height="32" 
                Background="{ui:ThemeResource ApplicationBackgroundBrush}" 
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="0,1,0,0">
            <Grid Opacity="0.75">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 1. Левая часть с анимацией -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0">
                    <ui:SymbolIcon Margin="0,0,8,0">
                        <ui:SymbolIcon.Style>
                            <Style TargetType="ui:SymbolIcon">
                                <Setter Property="Symbol" Value="Dismiss24"/>
                                <Setter Property="Foreground" Value="{ui:ThemeResource SystemFillColorCriticalBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Symbol" Value="Checkmark24"/>
                                        <Setter Property="Foreground" Value="{ui:ThemeResource SystemFillColorSuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:SymbolIcon.Style>
                    </ui:SymbolIcon>

                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusMessage, NotifyOnTargetUpdated=True}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                        <TextBlock.Triggers>
                            <!-- Анимация при каждом обновлении текста -->
                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </StackPanel>

                <!-- Далее идут разделители и остальные колонки из предыдущего шага -->
                <Rectangle Grid.Column="1" VerticalAlignment="Stretch" Width="1" 
                   Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,6"/>

                <TextBlock Grid.Column="2" Text="{Binding SmoothVoltage, StringFormat=\{0:N1\} V, ConverterCulture=ru}" VerticalAlignment="Center" Margin="15,0" 
                   FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                   Visibility="{c:Binding IsConnected}"/>

                <Rectangle Grid.Column="3" VerticalAlignment="Stretch" Width="1" 
                   Fill="{ui:ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,6"/>

                <TextBlock Grid.Column="4" Text="{Binding Mth}" VerticalAlignment="Center" Margin="15,0" 
                   FontSize="12" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                   Visibility="{c:Binding IsConnected}"/>
            </Grid>
        </Border>
        <Border Grid.Row="2" 
                Background="{ui:ThemeResource ApplicationBackgroundBrush}" 
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" 
                BorderThickness="0,1,0,0">
            <ui:DataGrid ColumnWidth="*" Opacity="1" Margin="5"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True"
                         EnableRowVirtualization="True"
                         Visibility="{c:Binding 'ItemsSource.Count > 0',
                                    RelativeSource={RelativeSource Self},
                                    FallbackValue=Collapsed}"
                         ItemsSource="{Binding DisplayHistorySource}"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         GridLinesVisibility="None"
                         RowDetailsVisibilityMode="VisibleWhenSelected"
                         CanUserSortColumns="False"
                         CanUserResizeColumns="False"
                         CanUserReorderColumns="False"
                         FontFamily="Bahnschrift"
                         SelectionMode="Single">
                <!--<ui:DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontSize" Value="10"/>
                </Style>
            </ui:DataGrid.CellStyle>-->
                <ui:DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}">
                        <Setter Property="Foreground" Value="Gray" />
                        <!--<Setter Property="FontWeight" Value="Regular" />-->
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="Margin" Value="0, 0, 0, 2" />
                        <Setter Property="Padding" Value="6, 4, 6, 2"/>
                    </Style>
                </ui:DataGrid.ColumnHeaderStyle>
                <ui:DataGrid.TextColumnElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="Margin" Value="0, 2"/>
                        <Setter Property="Padding" Value="0, 2, 0, 0"/>
                    </Style>
                </ui:DataGrid.TextColumnElementStyle>
                <ui:DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource DefaultDataGridCellStyle}">
                        <Setter Property="MinHeight" Value="0"/>
                        <!--<Setter Property="Height" Value="30"/>-->
                    </Style>
                </ui:DataGrid.CellStyle>
                <ui:DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DefaultDataGridRowStyle}">
                        <!--<Setter Property="Background" Value="DarkRed"/>-->
                        <Setter Property="Opacity" Value="0.75"/>
                        <Setter Property="Margin" Value="0, 0"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown"
                                     Handler="DataGridRow_PreviewMouseLeftButtonDown" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCrcValid}" Value="False">
                                <!--<Setter Property="Opacity" Value="0.1" />-->
                                <!--<Setter Property="Background"
                                        Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />-->
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="Opacity" Value="0.25" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:DataGrid.RowStyle>
                <ui:DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Grid>
                            <ui:DataGrid MaxHeight="185" Opacity="1"
                                         ColumnWidth="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemsSource="{Binding ProtoEvents}"
                                         IsReadOnly="True"
                                         AutoGenerateColumns="False"
                                         HorizontalAlignment="Left"
                                         CanUserSortColumns="False"
                                         CanUserResizeColumns="False"
                                         CanUserReorderColumns="False"
                                         SelectionMode="Single">
                                <ui:DataGrid.LayoutTransform>
                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                                    <!-- Уменьшит всё на 20% -->
                                </ui:DataGrid.LayoutTransform>
                                <ui:DataGrid.TextColumnElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="0, 2"/>
                                        <Setter Property="Padding" Value="0, 2, 0, 0"/>
                                    </Style>
                                </ui:DataGrid.TextColumnElementStyle>
                                <ui:DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource DefaultDataGridCellStyle}">
                                        <Setter Property="MinHeight" Value="0"/>
                                    </Style>
                                </ui:DataGrid.CellStyle>
                                <ui:DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}">
                                        <Setter Property="Foreground" Value="DarkGray" />
                                        <Setter Property="FontWeight" Value="Regular" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="Margin" Value="0, 0, 0, 2" />
                                        <Setter Property="Padding" Value="6, 4, 6, 2"/>
                                    </Style>
                                </ui:DataGrid.ColumnHeaderStyle>
                                <ui:DataGrid.Columns>
                                    <DataGridTextColumn Foreground="#A5D6FF"
                                                        Binding="{Binding Time, Mode =OneWay, StringFormat=\{0:N0\} us, ConverterCulture=ru}"
                                                        Header="Time" Width="*"/>
                                    <DataGridTextColumn Foreground="#D2A8FF"
                                                        Binding="{Binding MeanKkm, Mode =OneWay, StringFormat=\{0:N1\} mV, ConverterCulture=ru}"
                                                        Header="KKM" Width="*"/>
                                    <DataGridTextColumn Foreground="#FFA657"
                                                        Binding="{Binding VoltageArc, Mode =OneWay, StringFormat=\{0:N1\} V, ConverterCulture=ru}"
                                                        Header="Line" Width="*"/>
                                    <DataGridTextColumn Foreground="#7EE787"
                                                        Binding="{Binding MeanDin, Mode =OneWay, StringFormat=\{0:N1\} mV, ConverterCulture=ru}"
                                                        Header="DIN" Width="*"/>
                                    <DataGridTextColumn Foreground="#FF7B72"
                                                        Binding="{Binding M, Mode =OneWay, StringFormat=\{0\}·10⁻⁶, ConverterCulture=ru}"
                                                        Header="M" Width="*"/>
                                    <DataGridTextColumn Foreground="#FF7B72"
                                                        Binding="{Binding NoiseInt, Mode =OneWay, ConverterCulture=ru}"
                                                        Header="Noise" Width="*"/>
                                </ui:DataGrid.Columns>
                            </ui:DataGrid>
                        </Grid>
                    </DataTemplate>
                </ui:DataGrid.RowDetailsTemplate>
                <ui:DataGrid.Columns>
                    <!--<DataGridTextColumn Binding="{Binding Number}" Header="Number"/>-->
                    <DataGridTextColumn Foreground="#5E81AC" Width="1.5*"
                                        Binding="{Binding Time, StringFormat='{}{0:mm\\:ss\\.fff}', ConverterCulture=ru}"
                                        Header="Time">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <!-- По умолчанию текст виден -->
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <!-- Условие: если поле Polarity НЕ равно "+", скрываем -->
                                    <DataTrigger Binding="{Binding Polarity}" Value="-">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Foreground="#A3BE8C" Binding="{Binding Polarity, Mode =OneWay, ConverterCulture=ru}"
                                        Header="Pol" />
                    <DataGridTextColumn Foreground="#D08770" Binding="{Binding EvPhase2, Mode =OneWay, ConverterCulture=ru}"
                                        Header="Ph2" />
                    <DataGridTextColumn Foreground="#D08770" Binding="{Binding EvPhase4, Mode =OneWay, ConverterCulture=ru}"
                                        Header="Ph4" />
                    <DataGridTextColumn Foreground="#88C0D0" Width="1.5*"
                                        Binding="{Binding SigmaKkm, Mode =OneWay, StringFormat=\{0:N1\} mV, ConverterCulture=ru}"
                                        Header="∑ККМ" />
                    <DataGridTextColumn Foreground="#A5D6FF" Binding="{Binding Accumulator, Mode =OneWay, ConverterCulture=ru}"
                                        Header="Acc" />
                    <DataGridTextColumn Foreground="#B48EAD"
                                        Binding="{Binding LineVoltage, Mode =OneWay, StringFormat=\{0:N1\} V, ConverterCulture=ru}"
                                        Header="Line">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <!-- По умолчанию текст виден -->
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <!-- Условие: если поле Polarity НЕ равно "+", скрываем -->
                                    <DataTrigger Binding="{Binding Polarity, Mode =OneWay}" Value="-">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!--<DataGridTextColumn Foreground="#D08770" Binding="{Binding Crc16, ConverterCulture=ru}"
                                        Header="Crc16" />
                    <DataGridTextColumn Foreground="#D08770" Binding="{Binding CalcCrc, ConverterCulture=ru}"
                                        Header="CalcCrc" />-->
                </ui:DataGrid.Columns>
            </ui:DataGrid>
        </Border>
    </Grid>
</ui:FluentWindow>
